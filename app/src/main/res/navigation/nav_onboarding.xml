<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_onboarding"
    app:startDestination="@id/splash"
    >

    <fragment
        android:id="@+id/intro"
        android:name="com.example.basefragment.ui.onboarding.intro.IntroFragment"
        android:label="Intro"
        tools:layout="@layout/fragment_intro" >
        <action
            android:id="@+id/action_intro_to_permission"
            app:destination="@id/permission" />

        <action
            android:id="@+id/action_intro_to_home"
        app:destination="@id/nav_main"
        app:popUpTo="@id/nav_onboarding"
        app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/splash"
        android:name="com.example.basefragment.ui.onboarding.splash.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_language"
            app:destination="@id/language"
            app:popUpTo="@id/splash"
            app:popUpToInclusive="true" />

        <!-- Các lần sau → vào thẳng Intro -->
        <action
            android:id="@+id/action_splash_to_intro"
            app:destination="@id/intro"
            app:popUpTo="@id/splash"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/permission"
        android:name="com.example.basefragment.ui.onboarding.permission.PermissionFragment"
        android:label="Permission"
        tools:layout="@layout/fragment_permission" >
        <action
            android:id="@+id/action_permission_to_home"
            app:destination="@id/nav_main"
            app:popUpTo="@id/nav_onboarding"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/language"
        android:name="com.example.basefragment.ui.language.LanguageFragment"
        android:label="Language"
        tools:layout="@layout/fragment_language" >
        <action
            android:id="@+id/action_language_to_intro"
            app:destination="@id/intro" />
    </fragment>
</navigation>