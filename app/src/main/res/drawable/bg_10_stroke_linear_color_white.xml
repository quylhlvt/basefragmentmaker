<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ✅ Layer 1: Viền gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#7EFEFD"
                android:endColor="#F5A8F6"
                android:type="linear" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <!-- ✅ Layer 2: Trong suốt hoàn toàn -->
    <item
        android:left="5dp"
        android:top="5dp"
        android:right="5dp"
        android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
            <corners android:radius="10dp" />
        </shape>
    </item>

</layer-list>