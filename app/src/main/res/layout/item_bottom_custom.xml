<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:layout_margin="2dp"
    >

    <FrameLayout
        android:id="@+id/frame1"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="2dp"
        android:elevation="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLayer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="16dp"
            app:strokeWidth="1.6dp"
            app:cardBackgroundColor="@color/app_color8"
            app:strokeColor="@color/app_color7">
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLayerImg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="16dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/app_color9"
                android:layout_marginBottom="4dp">
                <ImageView
                    android:id="@+id/imvImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:adjustViewBounds="true"
                    android:src="@drawable/img_permission" />
            </com.google.android.material.card.MaterialCardView>

            <!--            imvImage-->


            <!--        sflShimmer-->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/sflShimmer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:shimmer_auto_start="true"
                app:shimmer_base_alpha="0.7"
                app:shimmer_direction="left_to_right"
                app:shimmer_duration="1800"
                app:shimmer_highlight_alpha="0.6"
                app:shimmer_shape="linear">
                <!-- View nền để shimmer quét qua -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#818181" />
            </com.facebook.shimmer.ShimmerFrameLayout>
        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

    <View
        android:id="@+id/view"
        android:elevation="1dp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="16dp"
        android:layout_marginHorizontal="2dp"
        android:layout_marginTop="2dp"
        app:strokeWidth="0dp"
        app:layout_constraintStart_toStartOf="@+id/frame1"
        app:layout_constraintEnd_toEndOf="@+id/frame1"
        app:layout_constraintTop_toTopOf="@+id/frame1"
        app:layout_constraintBottom_toBottomOf="@+id/frame1"/>
    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:elevation="1dp"
        android:id="@+id/focus"
        android:layout_height="0dp"
        android:visibility="invisible"
        app:cardBackgroundColor="@color/shadown_item_cate"
        app:layout_constraintStart_toStartOf="@+id/view"
        app:layout_constraintEnd_toEndOf="@+id/view"
        app:layout_constraintTop_toTopOf="@+id/view"
        app:cardCornerRadius="16dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/view"/>
</androidx.constraintlayout.widget.ConstraintLayout>