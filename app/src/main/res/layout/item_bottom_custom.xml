<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:layout_marginVertical="6dp"
    android:layout_marginEnd="10dp">

    <!--    cvContent-->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!--        vFocus-->
        <View
            android:id="@+id/vFocus"
            android:background="@drawable/bg_10_stroke_linear_color_white"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!--            imvImage-->
        <ImageView
            android:layout_margin="2dp"
            android:id="@+id/imvImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/sflShimmer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:shimmer_auto_start="true"
            app:shimmer_base_alpha="0.7"
            app:shimmer_direction="left_to_right"
            app:shimmer_duration="1800"
            app:shimmer_highlight_alpha="0.6"
            app:shimmer_shape="linear">
            <!-- View nền để shimmer quét qua -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#818181" />
        </com.facebook.shimmer.ShimmerFrameLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>