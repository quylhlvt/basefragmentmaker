<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="40dp"
    android:background="@color/transparent"
    android:layout_marginHorizontal="8dp"
    app:cardBackgroundColor="@color/shadown_item_cate"
    android:layout_marginBottom="8dp"
    >
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"

        >



        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="40dp"
                app:strokeWidth="10dp"
                app:strokeColor="#FFF5FE"
                app:cardBackgroundColor="#FBE1FA"
                android:outlineAmbientShadowColor="#E8C0F5"

                >

                <!--            imvImage-->
                <ImageView
                    android:id="@+id/imvImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_permission" />

                <ImageView
                    android:id="@+id/btnDelete"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_margin="18dp"
                    android:src="@drawable/ic_delete" />

                <!--        btnEdit-->
                <ImageView
                    android:id="@+id/btnEdit"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="end"
                    android:layout_margin="18dp"
                    android:src="@drawable/ic_edit" />

                <!--        btnSelect-->
                <ImageView
                    android:id="@+id/btnSelect"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="end"
                    android:layout_margin="18dp"
                    android:src="@drawable/ic_not_select"
                    android:visibility="gone" />
            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>