<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.main.home.HomeFragment">

    <ImageView
        android:id="@+id/imageView3"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/img_bg_home" />

    <!--    layoutActionBar-->
    <FrameLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <include
            android:id="@+id/actionBar"
            layout="@layout/layout_actionbar" />
    </FrameLayout>

    <ImageView
        android:id="@+id/title_home"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="37dp"
        android:scaleType="centerCrop"
        android:src="@drawable/img_title_home"
        app:layout_constraintDimensionRatio="2.84:1.69"
        app:layout_constraintTop_toBottomOf="@+id/layoutActionBar"
        tools:layout_editor_absoluteX="37dp" />

    <!--    scvMain-->
    <ScrollView
        android:id="@+id/scvMain"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="0dp"
        android:elevation="1dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title_home">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnCreate"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintDimensionRatio="3.21:1.16"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/img_bg_home1"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="2.96:1.16"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.example.basefragment.core.extention.OuterStrokeShadownTextView
                    android:id="@+id/tv1"
                    style="@style/single_marquee"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/img_bg_tv1"
                    android:fontFamily="@font/baloo2_extrabold"
                    android:gravity="center"
                    android:paddingHorizontal="5dp"
                    android:shadowColor="@color/app_color"
                    android:shadowDx="5"
                    android:shadowDy="-5"
                    android:shadowRadius="5"
                    android:text="@string/pony_maker"
                    android:textColor="@color/app_color2"
                    android:textSize="28dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="2.1:0.86"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:outerStrokeColor="@color/app_color"
                    app:outerStrokeWidth="1dp" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/img_avatar1"
                    app:layout_constraintDimensionRatio="0.96:1.1"
                    app:layout_constraintEnd_toStartOf="@+id/tv1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_marginTop="16dp"
                android:id="@+id/btnCosPlay"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintDimensionRatio="3.21:1.16"
                app:layout_constraintTop_toBottomOf="@+id/btnCreate">

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/img_bg_home1"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="2.96:1.16"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.example.basefragment.core.extention.OuterStrokeShadownTextView
                    android:id="@+id/tv2"
                    style="@style/single_marquee"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/img_bg_tv1"
                    android:fontFamily="@font/baloo2_extrabold"
                    android:gravity="center"
                    android:paddingHorizontal="5dp"
                    android:shadowColor="@color/app_color"
                    android:shadowDx="5"
                    android:shadowDy="-5"
                    android:shadowRadius="5"
                    android:text="@string/cosplay"
                    android:textColor="@color/app_color2"
                    android:textSize="28dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="2.1:0.86"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:outerStrokeColor="@color/app_color"
                    app:outerStrokeWidth="1dp" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/img_avatar2"
                    app:layout_constraintDimensionRatio="0.96:1.1"
                    app:layout_constraintEnd_toStartOf="@+id/tv2"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_marginTop="16dp"
                android:id="@+id/btnRandom"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintDimensionRatio="3.21:1.16"
                app:layout_constraintTop_toBottomOf="@+id/btnCosPlay">

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/img_bg_home1"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="2.96:1.16"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.example.basefragment.core.extention.OuterStrokeShadownTextView
                    android:id="@+id/tv3"
                    style="@style/single_marquee"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/img_bg_tv1"
                    android:fontFamily="@font/baloo2_extrabold"
                    android:gravity="center"
                    android:paddingHorizontal="5dp"
                    android:shadowColor="@color/app_color"
                    android:shadowDx="5"
                    android:shadowDy="-5"
                    android:shadowRadius="5"
                    android:text="@string/cat_random"
                    android:textColor="@color/app_color2"
                    android:textSize="28dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="2.1:0.86"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:outerStrokeColor="@color/app_color"
                    app:outerStrokeWidth="1dp" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/img_avatar3"
                    app:layout_constraintDimensionRatio="0.96:1.1"
                    app:layout_constraintEnd_toStartOf="@+id/tv3"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_marginTop="16dp"
                android:id="@+id/btnMyAlbum"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintDimensionRatio="3.21:1.16"
                app:layout_constraintTop_toBottomOf="@+id/btnRandom">

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/img_bg_home1"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="2.96:1.16"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.example.basefragment.core.extention.OuterStrokeShadownTextView
                    android:id="@+id/tv4"
                    style="@style/single_marquee"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/img_bg_tv1"
                    android:fontFamily="@font/baloo2_extrabold"
                    android:gravity="center"
                    android:paddingHorizontal="5dp"
                    android:shadowColor="@color/app_color"
                    android:shadowDx="5"
                    android:shadowDy="-5"
                    android:shadowRadius="5"
                    android:text="@string/my_creation"
                    android:textColor="@color/app_color2"
                    android:textSize="28dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="2.1:0.86"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:outerStrokeColor="@color/app_color"
                    app:outerStrokeWidth="1dp" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/img_avatar4"
                    app:layout_constraintDimensionRatio="0.96:1.1"
                    app:layout_constraintEnd_toStartOf="@+id/tv4"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!--    flNativeCollab-->
    <!--    <FrameLayout-->
    <!--        android:id="@+id/flNativeCollab"-->
    <!--        android:layout_width="match_parent"-->
    <!--        android:layout_height="wrap_content"-->
    <!--        android:elevation="2dp"-->
    <!--        app:layout_constraintBottom_toBottomOf="parent">-->

    <!--        <include layout="@layout/ads_native_collap_avg_shimmer" />-->
    <!--    </FrameLayout>-->
</androidx.constraintlayout.widget.ConstraintLayout>