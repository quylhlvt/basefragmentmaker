<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/lnlBackground"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:weightSum="220">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        android:layout_weight="32"
        android:elevation="2dp"
        android:orientation="horizontal">
<FrameLayout
    android:id="@+id/btnBackgroundImage"
    android:layout_width="0dp"
    android:layout_weight="1"
    android:layout_marginEnd="6dp"
    android:layout_gravity="center"
    android:background="@drawable/img_bg_image_addcharacter"
    android:layout_height="match_parent">
    <TextView
        android:id="@+id/btnBackgroundImageTv"
        style="@style/single_marquee"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:paddingVertical="2dp"
        android:text="@string/image"
        android:fontFamily="@font/baloo2_bold"
        android:textColor="@color/app_color"
        android:textSize="20sp"
        tools:ignore="NestedWeights" />
</FrameLayout>

        <FrameLayout
            android:layout_marginStart="6dp"
            android:id="@+id/btnBackgroundColor"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_gravity="center"
            android:background="@drawable/img_bg_color_addcharacter"
            android:layout_height="match_parent">
        <TextView
            android:id="@+id/btnBackgroundColorTv"
            style="@style/single_marquee"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingVertical="2dp"
            android:text="@string/color"
            android:fontFamily="@font/baloo2_bold"
            android:textColor="@color/app_color"
            android:textSize="20sp" />
        </FrameLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="7dp"
        android:layout_weight="188">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcvBackgroundImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="4.5dp"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="5"
            tools:listitem="@layout/item_background_image" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcvBackgroundColor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="4.5dp"
            android:visibility="gone"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="5"
            tools:listitem="@layout/item_background_color" />
    </FrameLayout>

</LinearLayout>